GEMINI_API_KEY=
NVIDIA_API_KEY=
GENIUS_ACCESS_TOKEN=

EMBEDDING_PROVIDER=gemini
DJ_PROVIDER=college
HYDE_PROVIDER=nim
TAGGING_PROVIDER=gemini
VECTOR_DB_PROVIDER=pgvector

# Automatic task-provider failover for tagging, DJ generation, and HyDE.
# Chain order is primary -> secondary -> tertiary.
PROVIDER_FAILOVER_ENABLED=true
PROVIDER_FAILOVER_CHAIN=gemini,nim,college
PROVIDER_CIRCUIT_FAILURE_THRESHOLD=3
PROVIDER_CIRCUIT_WINDOW_SECONDS=300
PROVIDER_CIRCUIT_COOLDOWN_SECONDS=60
PROVIDER_FAILOVER_PROVIDER_ATTEMPTS=2

# # optional college creds for testing RAG with college data source
COLLEGE_BASE_URL=
COLLEGE_USERNAME=
COLLEGE_PASSWORD=

# NVIDIA NIM (for tagging + HyDE — set LLM_PROVIDER=nim to use this stack)
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_TAGGING_MODEL=meta/llama-3.3-70b-instruct
NIM_HYDE_MODEL=meta/llama-3.3-70b-instruct

# Song enrichment services
LASTFM_API_KEY=

# Shared PostgreSQL database (same instance as the orchestrator)
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
